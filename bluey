<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>HTML Launcher</title>
    <style>
        body { background: #111; color: #eee; display: flex; flex-direction: column; justify-content: center; align-items: center; height: 100vh; margin: 0; font-family: sans-serif; }
        .container { text-align: center; width: 90%; max-width: 600px; }
        textarea { width: 100%; height: 200px; background: #222; color: #0f0; border: 1px solid #444; border-radius: 8px; padding: 15px; font-family: monospace; margin-bottom: 20px; resize: none; }
        button { padding: 15px 35px; font-size: 18px; background: #27ae60; color: white; border: none; border-radius: 5px; cursor: pointer; }
        button:hover { background: #2ecc71; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Paste HTML Code Below</h1>
        <textarea id="codeBody" placeholder="Paste your <html> code here..."></textarea>
        <br>
        <button onclick="runCode()">Launch in Standalone Window</button>
    </div>

    <script>
        function runCode() {
            const userCode = document.getElementById('codeBody').value;
            if (!userCode.trim()) { alert("Paste your code first!"); return; }

            // Opens window with custom size and no browser toolbars
            const features = 'width=1000,height=700,menubar=no,toolbar=no,location=no,status=no,resizable=yes';
            const newWindow = window.open('', 'GameWindow', features);
            
            // Injects your code into the new window
            newWindow.document.open();
            newWindow.document.write(userCode);
            newWindow.document.close();
        }
    </script>
</body>
</html>
